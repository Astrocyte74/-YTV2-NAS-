show_help() {
    cat << EOF
${CYAN}YTV2 Management CLI${NC}

Usage: ytv2 [command] [options]

Commands:
  ${GREEN}status${NC}              Show server status and access URLs
  ${GREEN}stats${NC}               Show dashboard statistics (reports, queues, storage)
  ${GREEN}restart${NC}             Safely restart all servers (preserves URLs)
  ${GREEN}logs [service] [n]${NC}  Show recent logs (default: backend, 50 lines)
  ${GREEN}verify${NC}              Verify setup and detect issues
  ${GREEN}agent${NC}               Show quick reference for Claude agents
  ${GREEN}help${NC}                Show this help message

Examples:
  ytv2 status              # Check if servers are running
  ytv2 stats               # See dashboard statistics
  ytv2 restart             # Restart all servers safely
  ytv2 logs ytv2-dashboard # Show dashboard logs
  ytv2 verify              # Verify everything is configured correctly
  ytv2 agent               # Show agent quick reference

Shortcut: You can use 'ytv2' without arguments to show status.
EOF
}

# Main
cd "$BACKEND_DIR" 2>/dev/null || true

case "${1:-status}" in
    status)
        show_status
        ;;
    stats)
        show_stats
        ;;
    restart)
        restart_servers
        ;;
    logs)
        show_logs "${2:-youtube-summarizer-bot}" "${3:-50}"
        ;;
    verify)
        verify_setup
        ;;
    agent)
        show_agent_info
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        print_error "Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
